<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 600" width="1200" height="600">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FF6B9D;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#E84B7E;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1200" height="600" fill="url(#grad1)"/>
  <circle cx="900" cy="150" r="120" fill="rgba(255,255,255,0.1)"/>
  <circle cx="200" cy="500" r="100" fill="rgba(255,255,255,0.05)"/>
  
  <!-- Car Icon -->
  <g transform="translate(400, 250)">
    <!-- Car body -->
    <rect x="50" y="80" width="200" height="100" rx="10" fill="white" opacity="0.9"/>
    <!-- Roof -->
    <polygon points="80,80 220,80 200,40 100,40" fill="white" opacity="0.9"/>
    <!-- Windows -->
    <rect x="100" y="50" width="40" height="30" fill="#87CEEB" opacity="0.6"/>
    <rect x="160" y="50" width="40" height="30" fill="#87CEEB" opacity="0.6"/>
    <!-- Wheels -->
    <circle cx="120" cy="185" r="25" fill="#333"/>
    <circle cx="210" cy="185" r="25" fill="#333"/>
    <!-- Wheel details -->
    <circle cx="120" cy="185" r="15" fill="#666"/>
    <circle cx="210" cy="185" r="15" fill="#666"/>
  </g>
  
  <!-- Text -->
  <text x="600" y="150" font-size="48" font-weight="bold" fill="white" text-anchor="middle">Herway</text>
  <text x="600" y="200" font-size="24" fill="white" text-anchor="middle">Women-Only Taxi Service</text>
</svg>